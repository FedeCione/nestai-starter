# Copy to .env and fill in values

# Runtime
NODE_ENV=development
PORT=3000

# Postgres (matches docker-compose.yml defaults)
DATABASE_URL=postgres://nestai:nestai@localhost:5432/nestai

# Auth — JWT_SECRET must be at least 32 chars. Generate with: openssl rand -hex 32
JWT_SECRET=replace-me-with-at-least-32-chars-of-random-hex
JWT_EXPIRES_IN=15m

# Groq (https://console.groq.com/keys) — leave empty to run /ai/generate in demo mode
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Rate limit (global). Defaults: 60 req / 1h / identity (user id or IP)
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX=60

# CORS / origin allow-list. Comma-separated, empty = same-origin only
# Example: ALLOWED_ORIGINS=http://localhost:3000,https://your-app.example
ALLOWED_ORIGINS=
